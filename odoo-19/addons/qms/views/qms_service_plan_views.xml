<odoo>
    <!-- Declarative views for qms.service.plan (the provider's sellable products). -->

    <record id="view_qms_service_plan_list" model="ir.ui.view">
        <field name="name">qms.service.plan.list</field>
        <field name="model">qms.service.plan</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="price"/>
            </list>
        </field>
    </record>

    <record id="view_qms_service_plan_form" model="ir.ui.view">
        <field name="name">qms.service.plan.form</field>
        <field name="model">qms.service.plan</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Standard Plan"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="price"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="description" placeholder="What does this plan include?"/>
                    <notebook>
                        <page string="Subscriptions">
                            <field name="service_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="customer_company_id"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_qms_service_plan" model="ir.actions.act_window">
        <field name="name">Service Plans</field>
        <field name="res_model">qms.service.plan</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first service plan</p>
            <p>A plan is a service the QMS provider sells to buyer companies.</p>
        </field>
    </record>
</odoo>
