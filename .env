# ── Odoo version ─────────────────────────────────────────────────────────────
# 17 is the current stable Community release. 18 also works on PostgreSQL 16.
ODOO_VERSION=17

# ── Web ports (host side) ────────────────────────────────────────────────────
# 3000 = ums-ui, 8080 = Plane — avoid those. 8069 is Odoo's standard port.
ODOO_PORT=8069
ODOO_LONGPOLLING_PORT=8072

# ── Database ─────────────────────────────────────────────────────────────────
# Odoo reuses the existing mypostgresql_db-container over my_docker_network.
# The actual DB credentials Odoo uses live in config/odoo.conf (single source of
# truth). The values below are for reference / the CREATE ROLE step only.
DB_HOST=mypostgresql_db-container
DB_PORT=5432
DB_USER=odoo
DB_PASSWORD=odoo_pass
